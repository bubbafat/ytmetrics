# Secrets — never commit
secrets/
config.toml
token*.json
client_secret*.json

# Local data & operational artifacts
*.db
*.db-wal
*.db-shm
*.prerestore
logs/
backups/
reports/          # generated briefing PDFs — contain private revenue/subscriber data

# But DO commit the seeded sample database used for offline analysis/tests
!sample/ytmetrics.sample.db

# Single-instance run lock
*.lock

# FUSE orphaned-handle artifacts (appear when a mounted file is held open)
.fuse_hidden*

# Local agent/editor config
.claude/

# Python / tooling
.venv/
__pycache__/
*.py[cod]
.mypy_cache/
.ruff_cache/
.pytest_cache/
dist/
build/
*.egg-info/
